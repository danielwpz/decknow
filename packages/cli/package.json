{
  "name": "@decknow/cli",
  "version": "0.0.1",
  "type": "module",
  "description": "CLI for previewing, validating, inspecting, and commenting on Decknow decks.",
  "license": "MIT",
  "bin": {
    "decknow": "./bin/decknow.js"
  },
  "files": [
    "bin",
    "client/comment-overlay.js",
    "src/main.js",
    "skills"
  ],
  "scripts": {
    "prepack": "node ../../scripts/sync-cli-skills.mjs"
  },
  "decknow": {
    "skill": {
      "name": "decknow",
      "path": "skills"
    }
  },
  "dependencies": {
    "@decknow/plugin-diagram-basic": "workspace:*",
    "@decknow/plugin-theme-paper-ink": "workspace:*",
    "@decknow/plugin-theme-terminal-green": "workspace:*",
    "@decknow/runtime-standard": "workspace:*",
    "yargs": "^17.7.2"
  },
  "peerDependencies": {
    "playwright": "^1.52.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  }
}
