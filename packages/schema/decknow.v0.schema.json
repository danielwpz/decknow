{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decknow.dev/schema/decknow.v0.schema.json",
  "title": "Decknow Deck AST v0",
  "type": "object",
  "required": ["version", "slides"],
  "properties": {
    "version": { "const": 0 },
    "theme": { "enum": ["terminal-green"] },
    "swipe": { "enum": ["auto", "none"] },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/slide" }
    }
  },
  "$defs": {
    "slide": {
      "type": "object",
      "required": ["content"],
      "properties": {
        "layout": { "enum": ["default", "hero", "center", "grid", "split"] },
        "align": { "enum": ["left", "center", "right"] },
        "surface": { "enum": ["auto", "none", "solid"] },
        "contentWidth": { "enum": ["auto", "prose", "wide", "full"] },
        "content": {
          "type": "array",
          "items": { "$ref": "#/$defs/node" }
        }
      }
    },
    "node": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "enum": [
            "title",
            "subtitle",
            "heading",
            "text",
            "list",
            "code",
            "quote",
            "link",
            "table",
            "grid",
            "region",
            "stack"
          ]
        },
        "text": { "type": "string" },
        "align": { "enum": ["left", "center", "right", "start", "end"] },
        "width": { "enum": ["auto", "prose", "wide", "full"] },
        "responsive": { "enum": ["auto", "none"] },
        "phoneColumns": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/node" }
        }
      },
      "additionalProperties": true
    }
  }
}
