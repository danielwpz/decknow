{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decknow.dev/schema/elements.v0.json",
  "name": "decknow-elements-v0",
  "version": "0.0.1",
  "description": "Initial HTML DSL element manifest for AI-authored Decknow decks.",
  "globalAttributes": {
    "align": ["left", "center", "right", "start", "end"],
    "tone": ["default", "muted", "accent", "strong", "success", "warning", "danger"],
    "surface": ["auto", "none", "solid", "glass"],
    "density": ["low", "medium", "high"],
    "width": ["auto", "prose", "wide", "full"],
    "class": "string",
    "style": "string"
  },
  "elements": {
    "dk-deck": {
      "description": "Root deck container.",
      "attributes": {
        "theme": ["terminal-green", "paper-ink"],
        "aspect": ["16:9"],
        "fit": ["contain"],
        "swipe": ["auto", "none"],
        "debug": "boolean"
      },
      "children": ["dk-slide"]
    },
    "dk-slide": {
      "description": "A fixed-stage slide.",
      "attributes": {
        "layout": ["default", "hero", "center", "grid", "split"],
        "align": ["left", "center", "right"],
        "surface": ["auto", "none", "solid"],
        "density": ["low", "medium", "high"],
        "content-width": ["auto", "prose", "wide", "full"]
      },
      "children": [
        "dk-title",
        "dk-subtitle",
        "dk-heading",
        "dk-text",
        "dk-list",
        "dk-code",
        "dk-quote",
        "dk-link",
        "dk-table",
        "dk-grid",
        "dk-region",
        "dk-stack",
        "dk-flow",
        "dk-pyramid",
        "dk-raw"
      ]
    },
    "dk-grid": {
      "description": "Core layout primitive for dividing a slide or region into grid areas.",
      "attributes": {
        "columns": "integer 1-6",
        "phone-columns": "integer 1-2",
        "rows": "integer 1-6",
        "gap": ["none", "sm", "md", "lg"],
        "align": ["start", "center", "end", "stretch"],
        "responsive": ["auto", "none"]
      },
      "children": ["dk-region"]
    },
    "dk-region": {
      "description": "A semantic region inside a grid or slide.",
      "attributes": {
        "area": "string",
        "span": "integer 1-6",
        "align": ["left", "center", "right", "start", "end"],
        "surface": ["auto", "none", "solid", "glass"],
        "valign": ["top", "center", "bottom", "stretch"],
        "content-width": ["auto", "prose", "wide", "full"]
      },
      "children": ["flow", "dk-flow", "dk-pyramid"]
    },
    "dk-stack": {
      "description": "A vertical or horizontal content group.",
      "attributes": {
        "direction": ["vertical", "horizontal"],
        "gap": ["none", "sm", "md", "lg"],
        "align": ["left", "center", "right", "start", "end", "stretch"],
        "valign": ["top", "center", "bottom", "stretch"],
        "responsive": ["auto", "none"],
        "content-width": ["auto", "prose", "wide", "full"]
      },
      "children": ["flow", "dk-flow", "dk-pyramid"]
    },
    "dk-flow": {
      "description": "Built-in diagram template for process flows. AI provides ordered semantic steps; runtime owns spacing, connectors, and responsive layout.",
      "attributes": {
        "direction": ["auto", "horizontal", "vertical"],
        "density": ["low", "medium", "high"],
        "align": ["left", "center"],
        "arrows": ["auto", "none"],
        "responsive": ["auto", "none"]
      },
      "children": ["dk-flow-step"]
    },
    "dk-flow-step": {
      "description": "One semantic step inside dk-flow.",
      "attributes": {
        "tone": ["default", "muted", "accent", "strong"],
        "emphasis": "boolean"
      },
      "children": ["flow"]
    },
    "dk-pyramid": {
      "description": "Built-in diagram template for layered hierarchy. AI provides ordered levels; runtime owns sizing and responsive layout.",
      "attributes": {
        "density": ["low", "medium", "high"],
        "fit": ["auto", "fill"],
        "label-placement": ["auto", "inside", "side", "callout"],
        "responsive": ["auto", "none"],
        "tip-ratio": "number"
      },
      "children": ["dk-pyramid-level"]
    },
    "dk-pyramid-level": {
      "description": "One semantic layer inside dk-pyramid.",
      "attributes": {
        "tone": ["default", "muted", "accent", "strong"],
        "emphasis": "boolean"
      }
    },
    "dk-raw": {
      "description": "Explicit escape hatch for raw HTML/CSS/JS when the core DSL is insufficient. AI should use this sparingly and include a reason.",
      "attributes": {
        "reason": "string",
        "risk": ["html", "css", "js", "mixed"]
      },
      "children": ["raw-html"]
    },
    "dk-title": {
      "description": "Primary slide title, equivalent to Markdown h1."
    },
    "dk-subtitle": {
      "description": "Lead subtitle or supporting copy."
    },
    "dk-heading": {
      "description": "Secondary heading, equivalent to Markdown h2-h4.",
      "attributes": {
        "level": ["2", "3", "4"],
        "align": ["left", "center", "right"]
      }
    },
    "dk-text": {
      "description": "Paragraph/body text, equivalent to Markdown paragraph.",
      "attributes": {
        "align": ["left", "center", "right"],
        "tone": ["default", "muted", "accent"]
      }
    },
    "dk-list": {
      "description": "Ordered or unordered list.",
      "attributes": {
        "ordered": "boolean",
        "marker": ["auto", "status", "none"],
        "reveal": "boolean"
      },
      "children": ["dk-item"]
    },
    "dk-item": {
      "description": "List item.",
      "attributes": {
        "tone": ["default", "muted", "accent", "strong", "success", "warning", "danger"]
      }
    },
    "dk-code": {
      "description": "Code block or inline code.",
      "attributes": {
        "language": "string",
        "inline": "boolean"
      }
    },
    "dk-quote": {
      "description": "Block quote.",
      "attributes": {
        "cite": "string"
      }
    },
    "dk-link": {
      "description": "Inline link.",
      "attributes": {
        "href": "string",
        "target": "string"
      }
    },
    "dk-table": {
      "description": "Basic table.",
      "children": ["dk-row", "dk-tr"]
    },
    "dk-row": {
      "description": "Table row.",
      "attributes": {
        "header": "boolean"
      },
      "children": ["dk-cell", "dk-th", "dk-td"]
    },
    "dk-tr": {
      "description": "Table row alias for HTML-familiar table DSL.",
      "attributes": {
        "header": "boolean"
      },
      "children": ["dk-cell", "dk-th", "dk-td"]
    },
    "dk-cell": {
      "description": "Table cell.",
      "attributes": {
        "align": ["left", "center", "right"]
      }
    },
    "dk-th": {
      "description": "Table header cell alias.",
      "attributes": {
        "align": ["left", "center", "right"]
      }
    },
    "dk-td": {
      "description": "Table data cell alias.",
      "attributes": {
        "align": ["left", "center", "right"]
      }
    },
    "dk-strong": {
      "description": "Inline strong emphasis."
    },
    "dk-em": {
      "description": "Inline emphasis."
    }
  },
  "notes": [
    "Core schema intentionally includes alignment, grid regions, and stack primitives. These are baseline authoring needs, not plugin features.",
    "Plugins should extend diagrams, charts, animations, exporters, and specialized components, not replace core layout primitives.",
    "Raw HTML/CSS/JS is allowed only through dk-raw or ordinary HTML inside a slide, but validators should warn unless the raw zone declares a reason. This keeps HTML-backed flexibility without making arbitrary markup the default authoring path."
  ]
}
